{
  "id": "obxd",
  "name": "OB-Xd",
  "abbrev": "OB",
  "version": "0.3.10",
  "description": "Virtual analog synthesizer based on Oberheim OB-X",
  "author": "reales (port: charlesvestal)",
  "license": "GPL-3.0",
  "ui": "ui.js",
  "dsp": "dsp.so",
  "api_version": 2,
  "capabilities": {
    "audio_out": true,
    "audio_in": false,
    "midi_in": true,
    "midi_out": false,
    "aftertouch": true,
    "chainable": true,
    "component_type": "sound_generator",
    "ui_hierarchy": {
      "levels": {
        "root": {
          "name": "OB-Xd",
          "params": [
            { "level": "banks", "label": "Banks" },
            {
              "key": "preset",
              "label": "Preset",
              "type": "int",
              "min": 0,
              "max_param": "preset_count",
              "default": 0
            },
            {
              "key": "cutoff",
              "label": "Cutoff",
              "type": "float",
              "min": 0.0,
              "max": 1.0,
              "default": 0.5,
              "step": 0.02,
              "unit": "%"
            },
            {
              "key": "resonance",
              "label": "Resonance",
              "type": "float",
              "min": 0.0,
              "max": 1.0,
              "default": 0.0,
              "step": 0.02,
              "unit": "%"
            },
            {
              "key": "filter_env",
              "label": "Filter Env",
              "type": "float",
              "min": 0.0,
              "max": 1.0,
              "default": 0.5,
              "step": 0.02,
              "unit": "%"
            },
            {
              "key": "attack",
              "label": "Attack",
              "type": "float",
              "min": 0.0,
              "max": 1.0,
              "default": 0.0,
              "step": 0.02,
              "unit": "%"
            },
            {
              "key": "decay",
              "label": "Decay",
              "type": "float",
              "min": 0.0,
              "max": 1.0,
              "default": 0.5,
              "step": 0.02,
              "unit": "%"
            },
            {
              "key": "sustain",
              "label": "Sustain",
              "type": "float",
              "min": 0.0,
              "max": 1.0,
              "default": 0.5,
              "step": 0.02,
              "unit": "%"
            },
            {
              "key": "release",
              "label": "Release",
              "type": "float",
              "min": 0.0,
              "max": 1.0,
              "default": 0.3,
              "step": 0.02,
              "unit": "%"
            },
            {
              "key": "osc_mix",
              "label": "Osc Mix",
              "type": "float",
              "min": 0.0,
              "max": 1.0,
              "default": 0.5,
              "step": 0.02,
              "unit": "%"
            },
            {
              "key": "osc2_detune",
              "label": "Detune",
              "type": "float",
              "min": 0.0,
              "max": 1.0,
              "default": 0.5,
              "step": 0.02,
              "unit": "%"
            },
            {
              "key": "lfo_rate",
              "label": "LFO Rate",
              "type": "float",
              "min": 0.0,
              "max": 1.0,
              "default": 0.3,
              "step": 0.02,
              "unit": "%"
            },
            {
              "key": "vibrato",
              "label": "Vibrato",
              "type": "float",
              "min": 0.0,
              "max": 1.0,
              "default": 0.0,
              "step": 0.02,
              "unit": "%"
            },
            {
              "key": "portamento",
              "label": "Portamento",
              "type": "float",
              "min": 0.0,
              "max": 1.0,
              "default": 0.0,
              "step": 0.02,
              "unit": "%"
            },
            {
              "key": "unison",
              "label": "Unison",
              "type": "float",
              "min": 0.0,
              "max": 1.0,
              "default": 0.0,
              "step": 0.02,
              "unit": "%"
            },
            {
              "key": "noise",
              "label": "Noise",
              "type": "float",
              "min": 0.0,
              "max": 1.0,
              "default": 0.0,
              "step": 0.02,
              "unit": "%"
            }
          ],
          "knobs": [
            "cutoff",
            "resonance",
            "filter_env",
            "attack",
            "decay",
            "sustain",
            "release",
            "osc_mix"
          ]
        },
        "banks": {
          "name": "Banks",
          "label": "Select Bank",
          "items_param": "fxb_bank_list",
          "select_param": "bank_index",
          "navigate_to": "root"
        }
      }
    }
  },
  "assets": {
    "path": "presets",
    "label": "Preset Banks",
    "extensions": [
      ".fxb"
    ],
    "optional": true,
    "description": "Optionally upload additional .fxb OB-Xd preset banks. Factory presets are included.",
    "hint": "Find OB-Xd .fxb banks at",
    "hint_url": "https://github.com/reales/OB-Xd",
    "hint_url_label": "OB-Xd GitHub"
  }
}
